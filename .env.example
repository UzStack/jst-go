# All settings can be overridden via APP_* env vars (nested keys use "_").
# Example: APP_DB_HOST=db, APP_JWT_SECRET=...

APP_ENV=development

APP_HTTP_HOST=0.0.0.0
APP_HTTP_PORT=8080
APP_HTTP_MAX_BODY_BYTES=1048576
# Comma-separated origins, or "*". e.g. https://app.example.com
APP_HTTP_CORS_ORIGINS=*
# Per-IP rate limit (req/sec); 0 disables. Burst defaults to 20.
APP_HTTP_RATE_LIMIT_RPS=0

APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres
APP_DB_NAME=jstgo
APP_DB_SSL_MODE=disable
# Run pending migrations on startup. Disable in prod and use `make migrate-up`.
APP_DB_AUTO_MIGRATE=true

# RS256 keys. Dev'da yo'q bo'lsa avtomatik generatsiya bo'ladi.
# PRODUCTION: har deploy uchun YANGI kalit generatsiya qiling (make gen-keys),
# dev kalitlarni hech qachon prodda ishlatmang.
APP_JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
APP_JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
APP_JWT_ACCESS_TTL=15m
APP_JWT_REFRESH_TTL=168h

APP_LOG_LEVEL=debug
